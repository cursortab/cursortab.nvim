-- old.txt --
import numpy as np

def bubble_sort(arr):
    for i in range(len(arr)):
        for j in range(len(arr) - i - 1):
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
    return arr

if __name__ == "__main__":
    arr = np.array([64, 34, 25, 12, 22, 11, 90])
    sorted_arr = bubble_sort(arr)


-- new.txt --
import numpy as np

def bubble_sort(arr):
    for i in range(len(arr)):
        for j in range(len(arr) - i - 1):
            if arr[j] > arr[j + 1]:
                arr[j], arr[j + 1] = arr[j + 1], arr[j]
    return arr

if __name__ == "__main__":
    arr = np.array([64, 34, 25, 12, 22, 11, 90])
    sorted_arr = bubble_sort(arr)
    print(sorted_arr)

